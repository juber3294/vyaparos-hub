NODE_ENV=development
APP_NAME=VyaparOS API
API_PREFIX=/api/v1
PORT=4000
PUBLIC_APP_URL=http://localhost:8081
DATABASE_URL=mysql://vyaparos:vyaparos@localhost:3306/vyaparos
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-64-char-access-secret
JWT_REFRESH_SECRET=replace-with-64-char-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGINS=http://localhost:8080,http://localhost:8081
COOKIE_DOMAIN=localhost
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=300
PASSWORD_PEPPER=replace-with-password-pepper
ENCRYPTION_KEY=replace-with-32-byte-base64-key
LOCAL_STORAGE_PATH=./storage
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
